---
interface Props {
    title: string;
    tagline: string;
    downloadUrl: string;
}

const { title, tagline, downloadUrl } = Astro.props;
---

<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-container">
        <div class="hero-screenshot">
            <div class="screenshot-frame">
                <img src="/screenshot.png" alt="Reledger Dashboard" />
            </div>
        </div>
        <div class="hero-content">
            <div class="hero-badge">Early Public Testing</div>
            <h1 class="hero-title">{title}</h1>
            <p class="hero-tagline">{tagline}</p>
            <div class="hero-badges">
                <a
                    href={downloadUrl}
                    class="hero-cta"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                        ></path>
                    </svg>
                    Download
                </a>
                <div class="hero-platforms">
                    <span class="platform-badge">Windows</span>
                    <span class="platform-badge">macOS</span>
                </div>
            </div>
            <div class="hero-tech">
                <span class="tech-badge">Electron</span>
                <span class="tech-badge">React</span>
                <span class="tech-badge">TypeScript</span>
                <span class="tech-badge">SQLite</span>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 4rem 2rem;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse 100% 100% at 50% 0%,
                rgba(229, 192, 123, 0.04),
                transparent 60%
            ),
            radial-gradient(
                ellipse 100% 100% at 100% 100%,
                rgba(97, 175, 239, 0.03),
                transparent 50%
            ),
            var(--bg-primary);
        z-index: 0;
    }

    .hero-container {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4rem;
        max-width: 1500px;
        width: 100%;
        animation: fadeIn 1s ease-out;
    }

    .hero-screenshot {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .screenshot-frame {
        position: relative;
        width: 100%;
        max-width: 900px;
    }

    .screenshot-frame img {
        display: block;
        width: 100%;
        height: auto;
    }

    .hero-content {
        text-align: center;
    }

    .hero-badge {
        display: inline-block;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6875rem;
        font-weight: 500;
        color: #e5c07b;
        background: var(--accent-bg);
        padding: 0.375rem 0.75rem;
        border-radius: 2rem;
        margin-bottom: 1.5rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .hero-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 700;
        color: var(--text-primary);
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin: 0 0 1.25rem;
        text-wrap: balance;
    }

    .hero-tagline {
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: clamp(1rem, 1.5vw, 1.25rem);
        font-weight: 400;
        color: var(--text-secondary);
        margin: 0 0 2rem;
        text-wrap: balance;
        max-width: 480px;
        line-height: 1.6;
    }

    .hero-badges {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: var(--bg-primary);
        background: var(--text-primary);
        border: none;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .hero-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(245, 245, 245, 0.2);
    }

    .hero-cta svg {
        flex-shrink: 0;
    }

    .hero-platforms {
        display: flex;
        gap: 0.5rem;
    }

    .platform-badge {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6875rem;
        font-weight: 500;
        color: var(--text-secondary);
        background: var(--bg-elevated);
        padding: 0.375rem 0.625rem;
        border-radius: 0.375rem;
        border: 1px solid var(--border);
    }

    .hero-tech {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    @media (max-width: 900px) {
        .hero-container {
            flex-direction: column;
            text-align: center;
        }

        .hero-content {
            text-align: center;
        }

        .hero-badges {
            justify-content: center;
        }

        .hero-tech {
            justify-content: center;
        }

        .hero-tagline {
            margin-inline: auto;
        }
    }

    @media (max-width: 600px) {
        .hero {
            padding: 3rem 1.5rem;
            min-height: auto;
        }

        .hero-badges {
            flex-direction: column;
            gap: 1rem;
        }
    }

    .tech-badge {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.6875rem;
        font-weight: 400;
        color: var(--text-muted);
        padding: 0.25rem 0;
    }

    .tech-badge::after {
        content: "·";
        margin-left: 0.75rem;
        opacity: 0.4;
    }

    .tech-badge:last-child::after {
        display: none;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 900px) {
        .hero-container {
            grid-template-columns: 1fr;
            gap: 3rem;
            text-align: center;
        }

        .hero-content {
            text-align: center;
        }

        .hero-badges {
            justify-content: center;
        }

        .hero-tech {
            justify-content: center;
        }

        .hero-tagline {
            margin-inline: auto;
        }
    }

    @media (max-width: 600px) {
        .hero {
            padding: 3rem 1.5rem;
            min-height: auto;
        }

        .hero-badges {
            flex-direction: column;
            gap: 1rem;
        }
    }
</style>
